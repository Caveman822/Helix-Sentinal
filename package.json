{
  "name": "helix-sentinel",
  "version": "0.0.5",
  "description": "Helix ESLint shared config and custom rules",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "Caveman822",
  "license": "MIT",
  "peerDependencies": {
    "eslint": ">=8.0.0",
    "prettier": ">=3.0.0"
  },
  "dependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "typescript-eslint": "^8.60.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "bun run build.ts && tsc -p tsconfig.build.json",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.cjs"
  },
  "publishConfig": {
    "access": "public"
  }
}
